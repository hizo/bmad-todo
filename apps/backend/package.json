{
  "name": "@bmad-todo/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "node-pg-migrate up --migration-file-language ts --migrations-dir src/migrations --envPath ../../.env",
    "migrate:down": "node-pg-migrate down --migration-file-language ts --migrations-dir src/migrations --envPath ../../.env",
    "test": "dotenv -e ../../.env.test -e ../../.env -- node --test --import tsx/esm src/**/*.test.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@bmad-todo/shared": "workspace:*",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "node-pg-migrate": "^7.0.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  }
}
