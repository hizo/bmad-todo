{
  "name": "bmad-todo",
  "private": true,
  "scripts": {
    "test": "pnpm -r run test",
    "test:backend": "pnpm --filter @bmad-todo/backend test",
    "test:frontend": "pnpm --filter @bmad-todo/frontend test",
    "test:e2e": "playwright test",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "dotenv-cli": "^11.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
