{
  "name": "bmad-todo",
  "private": true,
  "scripts": {
    "test": "pnpm -r run test",
    "test:backend": "pnpm --filter @bmad-todo/backend test",
    "test:frontend": "pnpm --filter @bmad-todo/frontend test",
    "test:e2e": "playwright test",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@playwright/test": "^1.48.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
  }
}
